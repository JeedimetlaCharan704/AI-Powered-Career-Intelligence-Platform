NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/skillpilot?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-256-bit-secret
JWT_EXPIRES_IN=7d

# GitHub API (optional — for higher rate limit)
GITHUB_TOKEN=

# CORS
CORS_ORIGIN=http://localhost:5500

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
